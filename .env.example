# Personal Knowledge Base - Environment Variables Template
# Copy this file to .env and fill in actual values

# ==================== LLM Configuration ====================
# LLM API Key (required)
LLM_API_KEY=

# LLM API Base URL (default: DeepSeek)
LLM_API_BASE_URL=https://api.deepseek.com

# LLM Model Name
LLM_MODEL=deepseek-chat

# LLM Provider (deepseek/openai/anthropic/qwen/moonshot/etc.)
LLM_PROVIDER=deepseek

# ==================== Embedding Configuration ====================
# Embedding API Key (required for vector search)
EMBEDDING_API_KEY=

# Embedding API Base URL (default: SiliconFlow)
EMBEDDING_API_BASE_URL=https://api.siliconflow.cn

# Embedding Model Name
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ==================== Optional Configuration ====================
# OCR API Key (if using OCR features)
# OCR_API_KEY=

# Web Search API Key (if using search features)
# SEARCH_API_KEY=
